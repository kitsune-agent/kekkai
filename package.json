{
  "name": "@kitsune-agent/kekkai",
  "version": "1.0.0",
  "description": "Memory integrity scanner for AI agents — deterministic, AI-free defense against OWASP ASI06",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "kekkai": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "ai",
    "security",
    "memory",
    "integrity",
    "scanner",
    "owasp",
    "asi06",
    "agent",
    "memory-poisoning",
    "prompt-injection",
    "credential-leak",
    "sarif",
    "deterministic",
    "ai-free"
  ],
  "author": "kitsune-agent",
  "license": "MIT",
  "homepage": "https://github.com/kitsune-agent/kekkai#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kitsune-agent/kekkai.git"
  },
  "bugs": {
    "url": "https://github.com/kitsune-agent/kekkai/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.1"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ]
}
